        },
        "vite": {
            "optional": true
        }
    },
    "devDependencies": {
        "@types/node": "^25.3.5",
        "katex": "^0.16",
        "tsup": "^8.0",
        "typescript": "^5.8",
        "vite": "^7.0",
        "vitest": "^3.0"
    }
