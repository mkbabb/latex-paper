{
    "name": "@mkbabb/latex-paper",
    "version": "0.1.0",
    "type": "module",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js"
        },
        "./transform": {
            "types": "./dist/transform.d.ts",
            "import": "./dist/transform.js"
        },
        "./vite": {
            "types": "./dist/vite.d.ts",
            "import": "./dist/vite.js"
        }
    },
    "files": [
        "dist",
        "grammar"
    ],
    "scripts": {
